---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/home/Hero.astro';
import AudienceRouter from '../components/home/AudienceRouter.astro';
import WhatWeAre from '../components/home/WhatWeAre.astro';
import TrustBand from '../components/home/TrustBand.astro';
import GlobalCta from '../components/home/GlobalCta.astro';
import { getPage } from '../lib/ghost';

const page = await getPage('home');
---

<BaseLayout title="Home" description={page?.meta_description ?? undefined}>
  <Hero page={page} />
  <AudienceRouter />
  <WhatWeAre />
  <TrustBand />
  <GlobalCta />
</BaseLayout>
