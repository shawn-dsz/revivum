---
/*
 * BaseLayout — the site shell.
 * Every page extends this and passes its own title/description as props.
 * Header, footer, and TGA disclaimer render on every page.
 */
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import TgaDisclaimer from '../components/layout/TgaDisclaimer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Revivum — peptide therapeutics infrastructure for Australia.' } = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="revivum">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} — Revivum</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=DM+Sans:wght@300;400;500;600&family=Courier+Prime:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen flex flex-col bg-base-100 text-base-content">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <TgaDisclaimer />
    <Footer />
  </body>
</html>
